{
  "name": "roommateledger",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n server,client -c blue,magenta \"bun run dev:server\" \"bun run dev:client\"",
    "dev:server": "bun --watch server/index.ts",
    "dev:client": "vite",
    "build": "bun run build:client && bun run build:server",
    "build:client": "vite build",
    "build:server": "bun build server/index.ts --target bun --outfile dist/server/index.js",
    "start": "NODE_ENV=production bun dist/server/index.js"
  },
  "dependencies": {
    "@tailwindcss/forms": "^0.5.10",
    "hono": "^4.8.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^3.25.20"
  },
  "devDependencies": {
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^5.0.1",
    "autoprefixer": "^10.4.21",
    "bun-types": "^1.3.11",
    "concurrently": "^9.2.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vite": "^7.0.6"
  }
}
